# Install Homebrew (Linuxbrew) and its dependencies
apt-get update
apt-get install -y build-essential procps curl file git
su - %C2W_USER% -c "NONINTERACTIVE=1 /bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
su - %C2W_USER% -c "echo 'eval \"\$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)\"' >> ~/.profile"
